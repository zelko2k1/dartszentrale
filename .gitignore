# OS / editor
Thumbs.db
Desktop.ini
.DS_Store
*~

# Node (falls später ein Build/Framework dazukommt)
node_modules/
dist/
dev-dist/
build/
.cache/
*.log
npm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example
# Lokaler Seed-Runner mit Zugangsdaten – bleibt lokal
pocketbase/seed-remote.sh

# Lokale Import-Arbeitsdateien (Spielplan-CSVs o. Ä.) – enthalten evtl. Vereinsdaten, bleiben lokal
/import/

# Autodarts-Connector bleibt bewusst LOKAL, nicht im öffentlichen Repo (rechtl. Gründe:
# autodarts → Nodor → Winmau). Nur die ROADMAP-Erwähnung ist ok.
/docs/autodarts-api.md
/docs/plan-autodarts-autoscore.md
/spikes/autodarts/
# Fang-Regel: jede Datei/jeder Ordner mit "autodarts" im Namen – egal wo im Projekt.
# Greift auf DATEINAMEN, nicht auf Inhalte → ROADMAP.md (nennt autodarts nur im Text) ist NICHT betroffen.
*autodarts*
*Autodarts*

# Claude Code local settings
.claude/settings.local.json

# Generierte PDF-Artefakte (Quelle ist die jeweilige .md)
docs/*.pdf

# vom copy2share-Skill erzeugte Verteil-Bundles (nur im Projekt-Root, NICHT der Skill selbst)
/copy2share/

# Datei-basiertes Update (serve-dist.mjs zur Laufzeit): Ablageordner, Token & Temp – nie committen
/updates/
.update-token
.update-tmp/
app/dist.old/

# Automatische Backups (serve-dist.mjs) – enthalten Nutzerdaten, nie committen
/backup/

# Vom Einfach-Start (start-einfach.*) im Projekt-Root erzeugt – nie committen
# pb_data/ ist die PocketBase-DB mit Nutzerdaten
pb_data/
# heruntergeladenes Binary (Linux/Mac bzw. Windows) – nur das Binary, NICHT das ganze
# pocketbase/-Verzeichnis (sonst würden neue pb_migrations/pb_hooks stillschweigend ignoriert).
/pocketbase/pocketbase
/pocketbase/pocketbase.exe

# PocketBase-Automigrate-Artefakte: entstehen lokal, wenn provision.mjs Collections ändert und der
# Server Automigrate an hat. Das Schema kommt hier aus den HANDGESCHRIEBENEN Migrationen (…_baseline_
# schema, …_leagues_order …) + provision.mjs; die Auto-Snapshots (…_created_/_updated_/_deleted_…)
# sind redundant und würden den Migrations-Pfad brechen (Duplikat-Felder). Nie committen.
/pocketbase/pb_migrations/*_created_*.js
/pocketbase/pb_migrations/*_updated_*.js
/pocketbase/pb_migrations/*_deleted_*.js
