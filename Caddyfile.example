# DartsZentrale — Caddy-Reverse-Proxy mit Auto-HTTPS (schlanke Variante, ohne Coolify/Docker).
#
# NUR fuer den CLOUD-MODUS. on-board und LAN brauchen kein Caddy (kein Netz-Exposé
# bzw. Absicherung per Firewall/VPN). Coolify ist nur Homelab/Dev, nicht dieser Pfad.
#
# `einrichten-cloud.sh` GENERIERT /etc/caddy/Caddyfile aus den Domains automatisch —
# diese Datei ist die Referenz zum Nachvollziehen + fuer die manuellen Schritte #5/#9.
# Manuell: nach /etc/caddy/Caddyfile kopieren, <domain> ersetzen, dann:
#   sudo caddy validate --config /etc/caddy/Caddyfile
#   sudo systemctl reload caddy
#
# Caddy holt und erneuert die Let's-Encrypt-Zertifikate VOLLAUTOMATISCH.
# Voraussetzung: Ports 80 + 443 sind aus dem Internet erreichbar und die
# DNS-A-Records app.<domain> / db.<domain> zeigen auf diese Server-IP.
# Siehe docs/security-audit.md (Abschnitt „Caddyfile-Template", Findings #3/#5/#9).

# (optional) globale Optionen — E-Mail für Zertifikats-Benachrichtigungen:
# {
# 	email du@deinedomain.de
# }

# ── Basis-Security-Header (Befund #9/#13) ────────────────────────────────────
# Im Cloud-Modus setzt Caddy die Header. (app/nginx.conf ist das Pendant nur im
# Coolify-Homelab/Dev-Pfad — hier nicht relevant.)
# HSTS ist hier aktiv, weil Caddy AUSSCHLIESSLICH über HTTPS ausliefert.
# Caddy setzt den Server-Header nur auf "Caddy" (keine Version) — wir entfernen ihn ganz.
(security_headers) {
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}
}

# Frontend (statischer dist-Server, darts-web.service auf 127.0.0.1:4173)
app.deinedomain.de {
	encode zstd gzip
	import security_headers
	# App wird nirgends eingebettet → Clickjacking komplett verbieten.
	header X-Frame-Options "DENY"

	# #9 Content-Security-Policy — DEPLOYMENT-SPEZIFISCH, daher aus. ERST nach Test
	# einkommentieren. WICHTIG: 'connect-src' MUSS die PocketBase-Domain enthalten,
	# sonst schlägt jeder API-Aufruf fehl. (React setzt Inline-Styles via DOM →
	# 'style-src' braucht 'unsafe-inline'; Schriften sind ins Bundle gebacken.)
	# header Content-Security-Policy "default-src 'self'; connect-src 'self' https://db.deinedomain.de; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"

	reverse_proxy 127.0.0.1:4173
}

# PocketBase (darts-pocketbase.service auf 127.0.0.1:8090)
db.deinedomain.de {
	encode zstd gzip
	import security_headers
	# SAMEORIGIN (nicht DENY) — das PB-Admin-UI /_/ nutzt ggf. eigene Frames.
	header X-Frame-Options "SAMEORIGIN"

	# Standard: alles durchreichen.
	reverse_proxy 127.0.0.1:8090

	# #5 (empfohlen) Admin-Konsole /_/ nur aus deinem Netz erlauben.
	# WICHTIG: dafür die einzelne reverse_proxy-Zeile OBEN entfernen — Caddy darf
	# handle-Blöcke nicht mit einer nackten reverse_proxy-Direktive mischen.
	# IP per `curl ifconfig.me` ermitteln; /32 = genau diese eine IP.
	#   @admin path /_/*
	#   handle @admin {
	#   	@blocked not remote_ip 203.0.113.45/32 192.168.0.0/16
	#   	respond @blocked "Forbidden" 403
	#   	reverse_proxy 127.0.0.1:8090
	#   }
	#   handle {
	#   	reverse_proxy 127.0.0.1:8090
	#   }
}
